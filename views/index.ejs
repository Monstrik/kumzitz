<html>
  <head>
    <title>Kumzitz</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="/css/styles.css">
  </head>
  <body>
    <h1>🎸 Kumzitz</h1>

    <p>
      <a href="/admin">Admin Panel</a>
    </p>

    <% songs.forEach(song => { %>
    <div class="song">
      <h2><%= song.title %></h2>
        <div class="song-text">
        <%= song.chords %>
        </div>

      <%
        if (song.video_url) {
      %>
        <p><a href="<%= song.video_url %>" target="_blank">Video</a></p>
      <%
        }
      %>

      <p>
        <a href="/edit/<%= song.id %>">Edit</a> |
        <form method="POST" action="/delete/<%= song.id %>" style="display:inline;">
          <button type="submit" onclick="return confirm('Are you sure?')">Delete</button>
        </form>
      </p>

    </div>
    <% }) %>
  </body>
</html>
